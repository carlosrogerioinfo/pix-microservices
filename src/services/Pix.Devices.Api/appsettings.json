{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "UseSqlServer": "false",
  "ConnectionStrings": {
    "DatabaseConnection": "Host=localhost;Port=5432;Database=pix_db;User Id=postgres;Password=postgres;"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_USE_ENV_VAR_JWT_SECRET_KEY",
    "Audience": "https://localhost",
    "Issuer": "https://localhost",
    "TimeValidationToken": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
